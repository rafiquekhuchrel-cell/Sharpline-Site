---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map((product) => ({
    params: { id: product.id },
    props: { product },
  }));
}

const { product } = Astro.props;
const { name, tagline, price, format, formatTag, differentiator, description, whatsInside, whoFor, checkoutUrl, cardStyle, heroTag, category } = product.data;

const categoryEntry = await getEntry('categories', category);
const relatedProducts = (await getCollection('products'))
  .filter((p) => p.data.category === category && p.id !== product.id)
  .slice(0, 3);
---
<BaseLayout title={name} description={tagline}>
  <section class="pdp-hero">
    <div class="grid-bg"></div>
    <div class="container pdp-hero-inner">
      <div class="pdp-copy">
        {categoryEntry && (
          <a href={`/category/${categoryEntry.id}`} class="pdp-breadcrumb">&larr; {categoryEntry.data.name}</a>
        )}
        <p class="eyebrow on-dark">{formatTag}</p>
        <h1>{name}</h1>
        <p class="pdp-tagline">{tagline}</p>
        <div class="pdp-buy-row">
          <span class="pdp-price">{price === null ? 'Free' : `$${price}`}</span>
          <a href={checkoutUrl} class="btn btn-primary" target="_blank" rel="noopener">
            {price === null ? 'Get It Free' : 'Buy Now'} &rarr;
          </a>
        </div>
        <p class="pdp-format">{format}</p>
      </div>

      <div class="pdp-card-wrap">
        <div class={`doc-card-lg ${cardStyle}`}>
          <span class="dc-eyebrow">{formatTag}</span>
          <span class="dc-name">{name}</span>
          <span class="dc-line" style="width:85%"></span>
          <span class="dc-line" style="width:65%"></span>
          <span class="dc-line" style="width:75%"></span>
          <span class="dc-tag">{heroTag}</span>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container pdp-body">
      <div class="pdp-main">
        <div class="pdp-block">
          <p class="eyebrow">WHY THIS, NOT A STATIC TEMPLATE</p>
          <p class="pdp-differentiator">{differentiator}</p>
        </div>

        <div class="pdp-block">
          <h2>What you get</h2>
          <p>{description}</p>
        </div>

        <div class="pdp-block">
          <h2>What's inside</h2>
          <ul class="pdp-list">
            {whatsInside.map((item: string) => <li>{item}</li>)}
          </ul>
        </div>

        <div class="pdp-block">
          <h2>Who this is for</h2>
          <p>{whoFor}</p>
        </div>
      </div>

      <aside class="pdp-side">
        <div class="pdp-side-card">
          <span class="pdp-price-lg">{price === null ? 'Free' : `$${price}`}</span>
          <a href={checkoutUrl} class="btn btn-primary pdp-side-btn" target="_blank" rel="noopener">
            {price === null ? 'Get It Free' : 'Buy Now'} &rarr;
          </a>
          <p class="pdp-side-note">Instant download after checkout, delivered securely via Payhip.</p>
          <p class="pdp-side-note">Works in Word/Excel or Google Docs/Sheets &mdash; no macros, no subscription.</p>
        </div>
      </aside>
    </div>
  </section>

  {relatedProducts.length > 0 && (
    <section class="section section-alt">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">YOU MIGHT ALSO LIKE</p>
          <h2>More from {categoryEntry?.data.name}</h2>
        </div>
        <div class="product-grid">
          {relatedProducts.map((p) => <ProductCard product={p} />)}
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .pdp-hero {
    position: relative;
    background: var(--ink);
    overflow: hidden;
  }
  .pdp-hero-inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 40px;
    align-items: center;
    padding: 56px 0 64px;
  }
  .pdp-breadcrumb {
    display: inline-block;
    font-size: 14px;
    color: #8CA0A8;
    margin-bottom: 18px;
  }
  .pdp-breadcrumb:hover { color: var(--emerald-light); }
  .pdp-copy h1 { color: var(--white); font-size: 40px; margin-top: 12px; }
  .pdp-tagline { color: #B9C4C8; font-size: 18px; margin-top: 18px; line-height: 1.55; max-width: 480px; }
  .pdp-buy-row { display: flex; align-items: center; gap: 20px; margin-top: 32px; }
  .pdp-price { font-family: var(--font-mono); font-size: 30px; font-weight: bold; color: var(--emerald-light); }
  .pdp-format { color: #6E838C; font-size: 13.5px; margin-top: 16px; }

  .pdp-card-wrap { display: flex; justify-content: center; }
  .doc-card-lg {
    width: 320px;
    border-radius: 12px;
    padding: 34px;
    box-shadow: 0 30px 60px rgba(0,0,0,0.45);
    transform: rotate(3deg);
  }
  .doc-card-lg.paper { background: var(--paper); }
  .doc-card-lg.dark { background: var(--ink2); }
  .doc-card-lg .dc-eyebrow { display:block; font-family: var(--font-mono); font-size: 11px; letter-spacing: 2px; font-weight: bold; color: var(--emerald-dark); }
  .doc-card-lg.dark .dc-eyebrow { color: var(--emerald-light); }
  .doc-card-lg .dc-name { display:block; font-family: var(--font-display); font-weight: 700; font-size: 19px; margin-top: 12px; color: var(--text); }
  .doc-card-lg.dark .dc-name { color: var(--white); }
  .doc-card-lg .dc-line { display:block; height: 7px; background: #E7E2D3; border-radius: 3px; margin-top: 14px; }
  .doc-card-lg.dark .dc-line { background: rgba(255,255,255,0.14); }
  .doc-card-lg .dc-tag { display: inline-block; font-family: var(--font-mono); font-size: 10.5px; font-weight: bold; background: var(--emerald); color: white; padding: 5px 12px; border-radius: 20px; margin-top: 22px; }

  .pdp-body {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 56px;
    align-items: start;
  }
  .pdp-block { margin-bottom: 40px; }
  .pdp-block h2 { font-size: 24px; margin-bottom: 14px; }
  .pdp-block p { color: var(--text); font-size: 16.5px; line-height: 1.65; }
  .pdp-differentiator { font-size: 19px; font-weight: 500; color: var(--ink); line-height: 1.5; margin-top: 10px; }
  .pdp-list { list-style: none; }
  .pdp-list li {
    padding: 12px 0 12px 30px;
    border-bottom: 1px solid var(--line);
    position: relative;
    font-size: 16px;
  }
  .pdp-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--emerald);
    font-weight: bold;
  }

  .pdp-side-card {
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 28px;
    position: sticky;
    top: 100px;
  }
  .pdp-price-lg { display: block; font-family: var(--font-mono); font-size: 32px; font-weight: bold; color: var(--ink); }
  .pdp-side-btn { width: 100%; margin-top: 18px; }
  .pdp-side-note { font-size: 13px; color: var(--slate); margin-top: 14px; line-height: 1.5; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 980px) {
    .pdp-hero-inner { grid-template-columns: 1fr; }
    .pdp-card-wrap { order: -1; }
    .pdp-body { grid-template-columns: 1fr; }
    .product-grid { grid-template-columns: 1fr; }
  }
</style>
