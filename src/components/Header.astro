---
import { getCollection } from 'astro:content';
const categories = (await getCollection('categories')).sort((a, b) => a.data.order - b.data.order);
const currentPath = Astro.url.pathname;
---
<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Sharpline home">
      <svg width="30" height="30" viewBox="0 0 30 30" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M4 6a3 3 0 013-3h16a3 3 0 013 3v12a3 3 0 01-3 3H12l-5 5v-5H7a3 3 0 01-3-3V6z" stroke="#0B1F2B" stroke-width="1.6" fill="none"/>
        <path d="M10.5 15.5l3-3 2.5 2.5 4.5-5" stroke="#1F9D6B" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
      </svg>
      <span class="logo-word">SHARP<span class="accent">LINE</span></span>
    </a>

    <nav class="main-nav" aria-label="Main">
      <a href="/shop" class:list={[currentPath === '/shop' && 'active']}>Shop All</a>
      {categories.map((cat) => (
        <a href={`/category/${cat.id}`} class:list={[currentPath === `/category/${cat.id}` && 'active']}>{cat.data.name}</a>
      ))}
      <a href="/bundle/complete-business-startup-bundle" class:list={[currentPath.startsWith('/bundle') && 'active']}>Startup Bundle</a>
      <a href="/blog" class:list={[currentPath.startsWith('/blog') && 'active']}>Blog</a>
      <a href="/about" class:list={[currentPath === '/about' && 'active']}>About</a>
    </nav>

    <div class="header-actions">
      <a href="/product/startup-launch-checklist" class="btn btn-secondary-light header-cta">Free Checklist</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--line);
    background: var(--paper);
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 18px;
    padding-bottom: 18px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }
  .logo-word {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 19px;
    letter-spacing: 0.5px;
    color: var(--ink);
  }
  .logo-word .accent { color: var(--emerald); }

  .main-nav {
    display: flex;
    gap: 28px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .main-nav a {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    white-space: nowrap;
    padding-bottom: 4px;
    border-bottom: 2px solid transparent;
  }
  .main-nav a:hover { color: var(--emerald-dark); }
  .main-nav a.active {
    border-bottom-color: var(--emerald);
    color: var(--emerald-dark);
    font-weight: 600;
  }

  .header-cta { padding: 10px 20px; font-size: 14px; flex-shrink: 0; }

  @media (max-width: 980px) {
    .main-nav { display: none; }
  }
</style>
